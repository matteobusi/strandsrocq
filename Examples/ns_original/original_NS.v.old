(*
  This file encodes the development of Section 4.3 of S&P'1998 paper
    "Strand spaces: why is a security protocol correct?" by Fabrega, Herzog, Guttman

  Here we consider the original Needham-Schroeder protocol;

  This took about two/three hours starting from ONS.v
*)

Require Import Coq.Init.Datatypes.
Require Import Arith.
Require Import Coq.Lists.List.
Require Import Coq.Lists.ListSet.
Require Import Coq.Lists.SetoidList.
Require Import Lia.
Require Import Relations.
Require Import Bool.

Import Coq.Lists.List.ListNotations.
Import Nat.
Open Scope list_scope.

Require Import RelMinimal.

(* We share the definitions with Terms file *)
Require Import Terms.
Require Import StrandsTactics.
Require Import Penetrator.
Import SymSig.

Require Import CpdtTactics.

Set Implicit Arguments.

Section ONS.
  (* Some elements of T are principals' names *)
  Parameter T__name : T -> Prop.
  (* Also, we assume an injective mapping between names and public keys *)
  Parameter PK : T -> K.
  Hypothesis PK_injective : forall A B, PK A = PK B -> A = B.

  (* The strand space is now defined as follows *)
  Inductive ONS_initiator_traces (A B N__a N__b : T) : list sT -> Prop :=
    | ONS_Init : T__name A /\ T__name B /\ ~ T__name N__a ->
        ONS_initiator_traces A B N__a N__b [
            ⊕ ⟨ N__a # A ⟩_(PK B);
            ⊖ ⟨ N__a # N__b ⟩_(PK A); (* No B's identity differently from NSL! *)
            ⊕ ⟨ N__b ⟩_(PK B)
        ].

  Inductive ONS_responder_traces (A B N__a N__b : T) : list sT -> Prop :=
    | ONS_Resp : T__name A /\ T__name B /\ ~ T__name N__b ->
        ONS_responder_traces A B N__a N__b [
            ⊖ ⟨ N__a # A ⟩_(PK B);
            ⊕ ⟨ N__a # N__b ⟩_(PK A); (* No B's identity differently from NSL! *)
            ⊖ ⟨ N__b ⟩_(PK B)
          ].

  (* Strands and nodes: notice the existential quantifier that expresses that initiator/responder strands are parametric in A, B, N__a, N__b that are *not* fixed once and forall *)
  Definition ONS_initiator_strand s :=
    exists A B N__a N__b, ONS_initiator_traces A B N__a N__b (tr s).
  Definition ONS_initiator_node (n : node__t) :=
    ONS_initiator_strand (strand n).

  Definition ONS_responder_strand s :=
    exists A B N__a N__b, ONS_responder_traces A B N__a N__b (tr s).
  Definition ONS_responder_node (n : node__t) :=
    ONS_responder_strand (strand n).

  (* The following results are analogous to the ones for NSL *)
  Lemma disjoint_regular_strands :
    forall s, ~ (ONS_initiator_strand s /\ ONS_responder_strand s).
  Proof.
    intros s [Hi Hr].
    inversion Hi as [A [B [N__a [N__b H0]]]]; inversion H0 as [_ Htr].
    inversion Hr as [A' [B' [N__a' [N__b' H1]]]]; inversion H1 as [_ Htr'].
    rewrite <- Htr' in Htr. inversion Htr.
  Qed.

  Lemma disjoint_regular_penetrator_strands :
    forall s, ~ ( (ONS_initiator_strand s \/ ONS_responder_strand s) /\ penetrator_strand s).
  Proof.
    intros s [[Hi|Hr] Hp].
    all: unfold penetrator_strand in Hp; apply P_is_penetrator in Hp.
    - inversion Hi as [A [B [N__a [N__b H0]]]]; inversion H0 as [_ Htr].
      inversion Hp. all: try now rewrite <- Htr in *.
    - inversion Hr as [A [B [N__a [N__b H0]]]]; inversion H0 as [_ Htr].
      inversion Hp. all: try now rewrite <- Htr in *.
  Qed.

  (* A simple tactic to reduce hypotheses/goals including term/uns_term and the like *)
  Ltac simplify_term := unfold uns_term; unfold term; simpl.

  (* Similarly to NSL, these premises are common throughout the development of ONS *)
  Parameter s : Σ.
  Parameters A B N__a N__b : T.
  Hypothesis A_is_name : T__name A.
  Hypothesis B_is_name : T__name B.
  Hypothesis N__a_not_name : ~T__name N__a.
  Hypothesis N__b_not_name : ~T__name N__b.

  (* Σ is just made of ONS strands *)
  Hypothesis Σ_is_ONS : forall s : Σ, penetrator_strand s \/ ONS_initiator_strand s \/ ONS_responder_strand s.
  (* Hypothesis C_is_bundle : is_bundle C. *)
  Hypothesis s_in_C : is_strand_of s C.
  Hypothesis s_is_NLS_responder : ONS_responder_strand s.
  Hypothesis trace_of_s : ONS_responder_traces A B N__a N__b (tr s).
  (* The inverse of PK A is not available to the attacker *)
  Hypothesis privA_npen : ~ penetrator_key (inv (PK A)).
  Hypothesis diff_nonces : N__a <> N__b.
  Hypothesis N__b_uniquely_originates : uniquely_originates N__b.

  (* A few easy/trivial facts *)
  Property term_of_s1 : term (s, 1) = (⊕ ⟨ N__a # N__b ⟩_(PK A)).
  Proof.
    simplify_term.
    inversion trace_of_s as [_ Htrs].
    now simpl.
  Qed.
  #[local] Hint Rewrite term_of_s1 : core.

  Lemma not_penetrator_is_regular : forall s : Σ,
    ~ penetrator_strand s -> ONS_initiator_strand s \/ ONS_responder_strand s.
  Proof.
    intros s Hnpen.
    destruct (Σ_is_ONS s).
    - contradiction.
    - easy.
  Qed.

  (* This section covers the responder's guarantee in the ONS protocol *)
  Section auth_responder_guarantee.
    (* Analogous to Lemma 4.3 for ONS *)
    Lemma N__b_originates_in_s1 :
        originates N__b (s, 1).
    Proof.
      (* intros s A B N__a N__b Hr Ht. *)
      specialize term_of_s1 as Ht.
      unfold originates.
      repeat split.
      - unfold is_positive; now rewrite Ht.
      - unfold uns_term; rewrite Ht; simpl; firstorder.
      - unfold term in Ht.
        inversion trace_of_s as [_ Htr].
        simpl in Ht.
        rewrite <- Htr in Ht. simpl in Ht. inversion Ht. subst.
        intros n' Hintra.
        assert (Hintra' := Hintra).
        apply (intrastrand_index_lt) in Hintra.
        (* simpl in Hintra. *)
        inversion Hintra as [Hn'|?].
        + simplify_term. rewrite Hn'.
          apply (intrastrand_same) in Hintra'. simpl in Hintra'.
          rewrite Hintra'.
          rewrite <- Htr. simpl. intros Hcontra.
          inversion Hcontra as [Hc|[Hc|[Hc|Hc]]].
          all: inversion Hc as [Hc'].
          * now symmetry in Hc'.
          * rewrite Hc' in *. easy.
        + lia.
    Qed.

    (* Some preliminaries for the analogous of Lemma 4.4 *)

    (* Set NS = { n ∈ C ∣ N__b ⊏ term n /\ uns_term (s, 1) ⊏̸ term n }, as defined in Lemma 4.4 *)
    Definition f_NS n := andb (subtermb N__b (uns_term n)) (negb (subtermb (uns_term (s, 1)) (uns_term n))).
    Definition NS : set node__t := filter f_NS (nodes_of_bundle C).

    Definition fc_NS t :=
      if subtermb N__b (uns t) then
        if negb (subtermb (uns_term (s, 1)) (uns t)) then true
        else false
      else false.
    #[local] Hint Unfold fc_NS: core.

    Lemma filter_n_t_NS : filter_n_t f_NS fc_NS.
    Proof.
      unfold filter_n_t.
      unfold fc_NS, f_NS, uns_term.
      intros n Hf.
      apply (andb_prop) in Hf as [Hfl Hfr].
      now rewrite Hfl, Hfr.
    Qed.

    Lemma filter_t_n_NS : filter_t_n f_NS fc_NS.
    Proof.
      unfold filter_t_n.
      unfold fc_NS, f_NS, uns_term.
      intros n n' Hfn' Hprec Hfcn.
      easy_strand3.
    Qed.

    (* NS is subset of the bundle C *)
    Lemma NS_subset : node_subset_of NS C.
    Proof.
      unfold node_subset_of.
      unfold nodes_with_term.
      intros n Hin.
      subst.
      apply filter_In in Hin.
      destruct Hin as [Hin Hsub].
      unfold is_node_of.
      assumption.
    Qed.

    (* NS is sign_closed *)
    Lemma NS_is_sign_closed : sign_closed C NS.
    Proof.
      unfold sign_closed.
      unfold NS.
      intros Hbundle Hsub m m'  Hm Hm' Huns.
      repeat (rewrite filter_In).
      all: now (unfold f_NS; rewrite <- Huns || rewrite Huns).
    Qed.

    Lemma NS_is_sign_closed_weak: sign_closed_weak C NS.
    Proof.
      apply (sign_closed_implies_weak NS_is_sign_closed).
    Qed.

    Lemma compute_minimal_NS :
    forall α n,
      α = tr (strand n) ->
      set_In n NS -> is_minimal (bundle_le C) n NS ->
      In (term n) (only_positives (first_slice (filter fc_NS α))).
    Proof.
      intros α n Htr Hin Hmin.
      assert (NS = filter f_NS (nodes_of_bundle C)) as HNS by (now unfold NS).
      apply (compute_minimal Htr HNS filter_n_t_NS filter_t_n_NS NS_is_sign_closed_weak Hin Hmin).
    Qed.

    Lemma NS_non_empty : NS <> nil.
    Proof.
      unfold NS.
      specialize (in_nil (A:=node__t)) as Hnil.
      assert (In (s, 2) NS) as Hs2in.
      {
        inversion trace_of_s as [_ Htrs].
        unfold NS.
        rewrite filter_In.
        split.
        - apply s_in_C.
          + now simpl.
          + simpl. rewrite <- Htrs. simpl. lia.
        - apply andb_true_intro; split.
          + apply subterm_iff_subtermb. unfold uns_term. unfold term. simpl. rewrite <- Htrs. simpl. auto.
          + rewrite Bool.negb_true_iff. apply subterm_iff_subtermb_not. unfold uns_term. unfold term. simpl. rewrite <- Htrs. simpl. intros [Hleft | Hright]. all: discriminate.
      }
      intro Hemp.
      rewrite <- Hemp in Hnil.
      specialize (Hnil (s, 2)).
      contradiction.
    Qed.

    (* Lemma 4.4 for ONS, part 1: NS always has a ⪯-minimal element *)
    Corollary NS_has_minimal : exists m, set_In m NS /\ is_minimal (bundle_le C) m NS.
    Proof.
      apply (RelMinimal.exists_minimal eq_node__t_dec (bundle_le_dec C) (bundle_le_antisymm C_is_bundle) (bundle_le_trans (C:=C)) NS_non_empty).
    Qed.

    (* Now we get ready to prove Lemma 4.4 for ONS part 2 *)
    Lemma inv_PK_A_never_originates_initiator :
      forall n : node__t, originates (inv (PK A)) n -> ~ ONS_initiator_strand (strand n).
    Proof.
      intros n Horig Hini. unfold ONS_initiator_strand in Hini.
      inversion Hini as [A [B [N__a [N__b Hitr]]]]; inversion Hitr as [_ Htrace].
      specialize (originates_super_pos Htrace Horig) as Hcontra; easy_strand3.
      all: try (apply subterm_iff_subtermb in Hsubterm; simpl in  Hsubterm; destruct Hsubterm as [?|[?|[?|?]]]; discriminate).
      - apply subterm_iff_subtermb in Hsubterm0. simpl in  Hsubterm0. destruct Hsubterm0. all: discriminate.
    Qed.

    Lemma inv_PK_A_never_originates_responder : forall n : node__t, originates (inv (PK A)) n -> ~ ONS_responder_strand (strand n).
    Proof.
      intros n Horig Hresp. unfold ONS_responder_strand in Hresp.
      inversion Hresp as [A [B [N__a [N__b H]]]]; inversion H as [_ Htrace].
      specialize (originates_super_pos Htrace Horig) as Hcontra; easy_strand3.
      apply subterm_iff_subtermb in Hsubterm; simpl in  Hsubterm.
      destruct Hsubterm as [?|[?|[?|?]]]; discriminate.
    Qed.

    Lemma N__b_originates_in_n__20 :
      forall t n__2, subtermb N__b t = true -> [⊕ t] = tr (strand n__2) -> originates N__b (strand n__2, 0).
    Proof.
      intros t n__2 Hsubterm H.
      unfold originates.
      repeat split.
      - unfold is_positive. unfold term. simpl. rewrite <- H. now simpl.
      - simplify_term. rewrite <- H. simpl.
        apply subterm_iff_subtermb in Hsubterm. simpl in Hsubterm.
        auto.
      - intros n' Hprec' _. specialize (intrastrand_index_lt Hprec') as Hindexlt.
        simpl in Hindexlt. lia.
    Qed.

    (* We also define here the set which is at the end of the proof of Lemma 4.4. *)
    (* Again, NOTE: this set is **NOT** sign closed as they say in the paper! *)
    Definition f_NT4_4 t n' n :=
      andb (subtermb t (uns_term n)) (bundle_ltb n n' C_is_bundle).
    Definition NT4_4 t n' : set node__t :=
      filter (f_NT4_4 t n') (nodes_of_bundle C).

    Definition fc_NT4_4 t t' :=
      subtermb t (uns t').
    #[local] Hint Unfold fc_NT4_4: core.

    Lemma filter_n_t_NT4_4 : forall t n', filter_n_t (f_NT4_4 t n') (fc_NT4_4 t).
    Proof.
      intros t n'.
      unfold filter_n_t.
      unfold fc_NT4_4, f_NT4_4, uns_term.
      intros n Hf.
      now apply (andb_prop) in Hf as [Hfl Hfr].
    Qed.

    Lemma filter_t_n_NT4_4 : forall t n', filter_t_n (f_NT4_4 t n') (fc_NT4_4 t).
    Proof.
      intros t n'.
      unfold filter_t_n.
      unfold fc_NT4_4, f_NT4_4, uns_term.
      intros n n0' Hfn' Hprec Hfcn.
      apply (andb_prop) in Hfn' as [Hfl Hfr].
      apply bundle_ltb_iff_bundle_lt in Hfr.
      specialize (ect_multi Hprec Hfr) as Hn_lt_n'.
      apply (andb_true_intro).
      rewrite <- bundle_ltb_iff_bundle_lt. split; assumption.
    Qed.

    Lemma NT4_4_is_sign_closed_weak :
      forall t n', sign_closed_weak C (NT4_4 t n').
    Proof.
      intros t n'.
      unfold sign_closed_weak.
      intros Hbundle Hsub m Hin Hneg.
      assert (Hinm:=Hin).
      apply Hsub in Hin.
      specialize (interstrand_exists_prec_positive_lt_uns Hbundle _ Hin Hneg) as [m' [Hin_m' [Hpos_m' [Hlt Huns]]]].
      exists m'.
      repeat split; try assumption.
      apply filter_In in Hinm as [_ Hfm].
      apply filter_In; split; try assumption.
      unfold f_NT4_4 in *.
      apply (andb_prop) in Hfm as [Hfm1 Hfm2].
      apply (andb_true_intro).
      rewrite <- Huns.
      rewrite <- bundle_ltb_iff_bundle_lt in *.
      split; try assumption.
      apply (ect_multi Hlt Hfm2).
    Qed.

    Lemma compute_minimal_NS4_4 :
      forall α t n' n,
      α = tr (strand n) ->
      set_In n (NT4_4 t n') ->
      is_minimal (bundle_le C) n (NT4_4 t n') ->
        In (term n) (only_positives (first_slice (filter (fc_NT4_4 t) α))).
    Proof.
      intros α t n' n Htr Hin Hmin.
      assert (NT4_4 t n' = filter (f_NT4_4 t n') (nodes_of_bundle C)) as HNT4_4 by (now unfold NT4_4).
      apply (compute_minimal Htr HNT4_4 (filter_n_t_NT4_4 t n') (filter_t_n_NT4_4 t n') (NT4_4_is_sign_closed_weak t n') Hin Hmin).
    Qed.

    Lemma n__2_0_in_NT4_4_l : forall n__2 g h,
      set_In n__2 NS -> is_minimal (bundle_le C) n__2 NS -> [⊖ g # h; ⊕ g; ⊕ h] = tr (strand n__2) ->
            (⊕ g) = term n__2 ->
              In n__2 (nodes_of_bundle C) ->
              set_In (strand n__2, 0) (NT4_4 (g # h) n__2).
    Proof.
      intros n__2 g h Hin Hmin Htr Hcontra0 Hn2_in_C.
      specialize (min_index_by_term n__2) as Hindexn2; easy_strand_mibt_simple.
      assert ((strand n__2, 0) ⟹+ n__2) as Hintraplus by (apply lt_intrastrand_index; repeat (simpl; auto)).
      specialize (intrastrand_trans_is_node_of C_is_bundle Hn2_in_C Hintraplus) as H0_isbundle.
      apply filter_In; unfold f_NT4_4; rewrite (andb_true_intro).
      all: repeat split; auto.
      - apply subterm_iff_subtermb. simplify_term. rewrite <- Htr. simpl. left. reflexivity.
      - apply bundle_ltb_iff_bundle_lt. apply (intrastrand_implies_ect C_is_bundle Hn2_in_C Hintraplus).
    Qed.

    Lemma n__2_0_in_NT4_4_r : forall n__2 g h,
    set_In n__2 NS -> is_minimal (bundle_le C) n__2 NS -> [⊖ g # h; ⊕ g; ⊕ h] = tr (strand n__2) ->
          (⊕ h) = term n__2 ->
            In n__2 (nodes_of_bundle C) ->
            set_In (strand n__2, 0) (NT4_4 (g # h) n__2).
    Proof.
      intros n__2 g h Hin Hmin Htr Hcontra0 Hn2_in_C.
      assert ((strand n__2, 0) ⟹+ n__2) as Hintraplus. {
        apply lt_intrastrand_index.
        specialize (min_index_by_term n__2) as Hindexn2; easy_strand_mibt_simple; simpl.
        lia. simpl; auto.
      }
      specialize (intrastrand_trans_is_node_of C_is_bundle Hn2_in_C Hintraplus) as H0_isbundle.
      apply filter_In; unfold f_NT4_4; rewrite (andb_true_intro).
      all: repeat split; auto.
      - apply subterm_iff_subtermb. simplify_term. rewrite <- Htr. simpl. left. reflexivity.
      - apply bundle_ltb_iff_bundle_lt. apply (intrastrand_implies_ect C_is_bundle Hn2_in_C Hintraplus).
    Qed.

    Lemma NT4_4_not_empty_l :
      forall n__2 g h,
        set_In n__2 NS ->
          is_minimal (bundle_le C) n__2 NS ->
            [⊖ g # h; ⊕ g; ⊕ h] = tr (strand n__2) ->
              (⊕ g) = term n__2 ->
                In n__2 (nodes_of_bundle C) ->
                  (NT4_4 (g # h) n__2) <> nil.
    Proof.
      intros n__2 g h Hin Hmin Htr Hcontra0 Hn2_in_C.
      specialize (n__2_0_in_NT4_4_l Hin Hmin Htr Hcontra0 Hn2_in_C) as Hn__2_in_NT4_4.
      destruct (NT4_4 (g # h) n__2).
      - contradiction.
      - intros Hc. discriminate Hc.
    Qed.

    Lemma NT4_4_not_empty_r :
      forall n__2 g h,
        set_In n__2 NS ->
          is_minimal (bundle_le C) n__2 NS ->
            [⊖ g # h; ⊕ g; ⊕ h] = tr (strand n__2) ->
              (⊕ h) = term n__2 ->
                In n__2 (nodes_of_bundle C) ->
                  (NT4_4 (g # h) n__2) <> nil.
    Proof.
      intros n__2 g h Hin Hmin Htr Hcontra0 Hn2_in_C.
      specialize (n__2_0_in_NT4_4_r Hin Hmin Htr Hcontra0 Hn2_in_C) as Hn__2_in_NT4_4.
      destruct (NT4_4 (g # h) n__2).
      - contradiction.
      - intros Hc. discriminate Hc.
    Qed.

    Lemma minimal_in_NT4_4_not_penetrator_l : forall n__2 n_min g h,
      set_In n_min (NT4_4 (g # h) n__2) -> is_minimal (bundle_le C) n_min (NT4_4 (g # h) n__2) ->
          set_In n__2 NS -> is_minimal (bundle_le C) n__2 NS ->
            (⊕ g) = term n__2 ->
              subtermb N__b g = true ->
                subtermb (uns_term (s, 1)) g = false ->
                  ~ penetrator_strand (strand n_min).
    Proof.
      intros n__2 n_min g h Hn_min_in Hn_min Hin Hmin Hcontra0 H_N__b_subterm_g H_s_1_nsubterm_g Hp.
      unfold penetrator_strand in Hp; apply P_is_penetrator in Hp.
      inversion Hp as [t'|g'|g'|g' h'|g' h'|k' Hpenkey'|k' h'|k' h'].
      all: specialize (compute_minimal_NS4_4 _ _ H Hn_min_in Hn_min) as Hcontra; easy_strand3.
      injection Hsubterm2 as Hh Hg.
      rewrite <- Hh in *.
      rewrite <- Hg in *.
      unfold is_minimal in Hn_min.
      assert (uns_term (strand n_min, 0) = uns_term n__2) as Hunseq. {
        unfold uns_term.
        rewrite <- Hcontra0.
        unfold term. simpl. rewrite <- H. now simpl.
      }

      assert (set_In (strand n_min,0) NS /\ C ⊢ (strand n_min,0) ≺ n_min) as [HinNS Hect]. {
        specialize (min_index_by_term n_min) as Hindexn_min; easy_strand_mibt_simple.
        apply filter_In in Hn_min_in as [Hn_min_in_C _].
        assert ((strand n_min,0) ⟹+ n_min) as Hintraplus by
          (apply lt_intrastrand_index; repeat (simpl; lia); repeat (simpl; auto)).
          specialize (intrastrand_trans_is_node_of C_is_bundle Hn_min_in_C Hintraplus) as H0_isbundle.
          split.
          - apply filter_In. unfold f_NS.
            rewrite -> (andb_true_intro).
            all: split; try easy.
            + simplify_term. now rewrite <- H.
            + rewrite Hunseq. unfold uns_term. rewrite <- Hcontra0. now apply (negb_true_iff).
          - apply (intrastrand_implies_ect C_is_bundle Hn_min_in_C Hintraplus).
      }

      assert ((strand n_min, 0) <> n__2) as Hn_min_neq_n2. {
        unfold not. intros Heq. rewrite <- Heq in Hcontra0. unfold term in Hcontra0. simpl in Hcontra0. rewrite <- H in Hcontra0. simpl in Hcontra0. discriminate Hcontra0.
      }

      assert (Hn_min_in':=Hn_min_in).
      apply filter_In in Hn_min_in' as [_ Hect2tmp].
      apply (andb_prop) in Hect2tmp as [_ Hect2].
      apply bundle_ltb_iff_bundle_lt in Hect2.
      specialize (ect_multi Hect Hect2) as Hect3.
      unfold is_minimal in Hmin. specialize (Hmin Hin _ HinNS Hn_min_neq_n2). apply (bundle_lt_then_le) in Hect3. contradiction.
    Qed.

    Lemma minimal_in_NT4_4_not_penetrator_r : forall n__2 n_min g h,
    set_In n_min (NT4_4 (g # h) n__2) -> is_minimal (bundle_le C) n_min (NT4_4 (g # h) n__2) ->
        set_In n__2 NS -> is_minimal (bundle_le C) n__2 NS ->
          (⊕ h) = term n__2 ->
            subtermb N__b h = true ->
              subtermb (uns_term (s, 1)) h = false ->
                ~ penetrator_strand (strand n_min).
    Proof.
      intros n__2 n_min g h Hn_min_in Hn_min Hin Hmin Hcontra0 H_N__b_subterm_g H_s_1_nsubterm_g Hp.
      unfold penetrator_strand in Hp; apply P_is_penetrator in Hp.
      inversion Hp as [t'|g'|g'|g' h'|g' h'|k' Hpenkey'|k' h'|k' h'].
      all: try specialize (compute_minimal_NS4_4 _ _ H Hn_min_in  Hn_min) as Hcontra; easy_strand3.
      injection Hsubterm2 as Hh Hg.
      rewrite <- Hh in *.
      rewrite <- Hg in *.
      unfold is_minimal in Hn_min.
      assert (uns_term (strand n_min, 1) = uns_term n__2) as Hunseq. {
        unfold uns_term.
        rewrite <- Hcontra0.
        unfold term. simpl. rewrite <- H. simpl. reflexivity.
      }

      assert (set_In (strand n_min, 1) NS /\ C ⊢ (strand n_min, 1) ≺ n_min) as [HinNS Hect]. {
        specialize (min_index_by_term n_min) as Hindexn_min; easy_strand_mibt_simple.
        apply filter_In in Hn_min_in as [Hn_min_in_C _].
        assert ((strand n_min,1) ⟹+ n_min) as Hintraplus by
        (apply lt_intrastrand_index; repeat (simpl; lia); repeat (simpl; auto)).
        specialize (intrastrand_trans_is_node_of C_is_bundle Hn_min_in_C Hintraplus) as H0_isbundle.
        split.
        -
        (* apply (NS_char (strand n_min,1)).  *)
          apply filter_In. unfold f_NS.
          rewrite -> (andb_true_intro).
          repeat split. assumption.
          split.
          + simplify_term. now rewrite <- H.
          + rewrite Hunseq. unfold uns_term. rewrite <- Hcontra0. now apply (negb_true_iff).
        - apply (intrastrand_implies_ect C_is_bundle Hn_min_in_C Hintraplus).
      }

      assert ((strand n_min, 1) <> n__2) as Hn_min_neq_n2. {
        unfold not. intros Heq. rewrite <- Heq in Hcontra0. unfold term in Hcontra0. simpl in Hcontra0. rewrite <- H in Hcontra0. simpl in Hcontra0. discriminate Hcontra0.
      }

      assert (Hn_min_in':=Hn_min_in).
      apply filter_In in Hn_min_in' as [_ Hect2tmp].
      apply (andb_prop) in Hect2tmp as [_ Hect2].
      apply bundle_ltb_iff_bundle_lt in Hect2.
      specialize (ect_multi Hect Hect2) as Hect3.
      unfold is_minimal in Hmin. specialize (Hmin Hin _ HinNS Hn_min_neq_n2). apply (bundle_lt_then_le) in Hect3. contradiction.
    Qed.

    Lemma minimal_in_NT4_4_not_initiator_l : forall n__2 n_min g h,
    set_In n_min (NT4_4 (g # h) n__2) -> is_minimal (bundle_le C) n_min (NT4_4 (g # h) n__2) ->
            uns_term (s, 1) = ⟨ N__a # N__b ⟩_ PK A ->
              subtermb (uns_term (s, 1)) g = false ->
                subtermb (uns_term (s, 1)) (g # h) = true ->
                  ~ ONS_initiator_strand (strand n_min).
    Proof.
      intros n__2 n_min g h Hn_min_in Hn_min Hunsterms1 Hsubterm2 Hsubterm4 Hi.
      inversion Hi as [A [B [N__a [N__b Hitr]]]]; inversion Hitr as [_ H].
      specialize (compute_minimal_NS4_4 _ _ H Hn_min_in Hn_min) as Hcontra; easy_strand3.
      * rewrite <- subterm_iff_subtermb in *.
        rewrite Hunsterms1 in *.
        inversion Hsubterm4 as [Heq|[Hg|Hh]].
        -- discriminate Heq.
        -- rewrite <- subterm_iff_subtermb_not in Hsubterm2. contradiction. (* Uses Hsubterm2 *)
        -- destruct Hsubterm as [Heasy|[Hpay|[Heasy|Heasy]]].
          all: try discriminate Heasy.
          injection Hpay as _ Hhh. rewrite Hhh in Hh. discriminate Hh.
      * rewrite <- subterm_iff_subtermb in *. destruct Hsubterm1 as [Heasy|Heasy]; repeat discriminate Heasy.
    Qed.

    Lemma minimal_in_NT4_4_not_initiator_r : forall n__2 n_min g h,
    set_In n_min (NT4_4 (g # h) n__2) -> is_minimal (bundle_le C) n_min (NT4_4 (g # h) n__2) ->
            uns_term (s, 1) = ⟨ N__a # N__b ⟩_ PK A ->
              subtermb (uns_term (s, 1)) h = false ->
                subtermb (uns_term (s, 1)) (g # h) = true ->
                  ~ ONS_initiator_strand (strand n_min).
    Proof.
      intros n__2 n_min g h Hn_min_in Hn_min Hunsterms1 Hsubterm2 Hsubterm7 Hi.
      inversion Hi as [A [B [N__a [N__b Hitr]]]]; inversion Hitr as [_ H].
      all: try specialize (compute_minimal_NS4_4 _ _ H Hn_min_in  Hn_min) as Hcontra; easy_strand3.
      * rewrite <- subterm_iff_subtermb in *.  rewrite <- subterm_iff_subtermb_not in *.
          rewrite Hunsterms1 in *.
          destruct Hsubterm7 as [Heq|[Hg|Hh]].
          -- discriminate Heq.
          -- destruct Hsubterm as [Heasy|[Hpay|[Heasy|Heasy]]]; repeat discriminate Heasy.
            injection Hpay as Hgg _. rewrite Hgg in Hg. discriminate Hg.
          -- contradiction.
      * rewrite <- subterm_iff_subtermb in *. destruct Hsubterm1 as [Heasy|Heasy]; repeat discriminate Heasy.
    Qed.

    Lemma minimal_in_NT4_4_not_responder_l : forall n__2 n_min g h,
    set_In n_min (NT4_4 (g # h) n__2) -> is_minimal (bundle_le C) n_min (NT4_4 (g # h) n__2) ->
            uns_term (s, 1) = ⟨ N__a # N__b ⟩_ PK A ->
              subtermb (uns_term (s, 1)) g = false ->
                subtermb (uns_term (s, 1)) (g # h) = true ->
                  ~ ONS_responder_strand (strand n_min).
    Proof.
      intros n__2 n_min g h Hn_min_in Hn_min Hunsterms1 Hsubterm2 Hsubterm4 Hr.
      inversion Hr as [A [B [N__a [N__b Hrtr]]]]; inversion Hrtr as [_ H].
      all: try specialize (compute_minimal_NS4_4 _ _ H Hn_min_in Hn_min) as Hcontra; easy_strand3.
      rewrite <- subterm_iff_subtermb in *. destruct Hsubterm0 as [Heasy|Hpay]. discriminate Heasy.
      rewrite <- subterm_iff_subtermb_not in *.
      rewrite Hunsterms1 in *.
      destruct Hsubterm4 as [Heq|[Hg|Hh]]. discriminate Heq. contradiction.
      destruct Hpay as [Hpayl|[Hpayl|Heasy]]. all: try discriminate Heasy.
      * injection Hpayl as _ Hhh. rewrite Hhh in Hh. discriminate Hh.
      * inversion Hpayl.
    Qed.

    Lemma minimal_in_NT4_4_not_responder_r : forall n__2 n_min g h,
    set_In n_min (NT4_4 (g # h) n__2) -> is_minimal (bundle_le C) n_min (NT4_4 (g # h) n__2) ->
            uns_term (s, 1) = ⟨ N__a # N__b ⟩_ PK A ->
              subtermb (uns_term (s, 1)) h = false ->
                subtermb (uns_term (s, 1)) (g # h) = true ->
                  ~ ONS_responder_strand (strand n_min).
    Proof.
      intros n__2 n_min g h Hn_min_in Hn_min Hunsterms1 Hsubterm2 Hsubterm7 Hr.
      inversion Hr as [A [B [N__a [N__b Hrtr]]]]; inversion Hrtr as [_ H].
      all: try specialize (compute_minimal_NS4_4 _ _ H Hn_min_in  Hn_min) as Hcontra; easy_strand3.

      rewrite <- subterm_iff_subtermb in *. destruct Hsubterm0 as [Heasy|Hpay].
      - discriminate Heasy.
      - rewrite <- subterm_iff_subtermb_not in *.
        rewrite Hunsterms1 in *.
        destruct Hsubterm7 as [Heq|[Hg|Hh]]. discriminate Heq. 2: contradiction.
        destruct Hpay as [Hpayl|[Hpayl|Heasy]]. all: try discriminate Heasy.
          + injection Hpayl as Hgg _. rewrite Hgg in Hg. inversion Hg.
          + inversion Hpayl.
    Qed.

    (* Lemma 4.4 part 2: the minimal node is regular and its sign is positive *)
    Lemma minimal_regular_and_positive :
        (* If n__2 is minimal of NS then ...*)
        forall n__2,
          set_In n__2 NS ->
          is_minimal (bundle_le C) n__2 NS ->
            is_positive n__2 /\ ~ penetrator_node n__2.
    Proof.
      inversion trace_of_s as [_ Htrs].
      destruct N__b_uniquely_originates as [n__o [Horig_n__o Hunique_n__o]].
      intros n__2 Hin Hmin.
      assert (Hin':=Hin).
      apply filter_In in Hin' as [Hn2_in_C _].
      (* positivity of n__2 is easy by Lemma 2.7 *)
      specialize (minimal_is_positive C_is_bundle NS_subset NS_is_sign_closed Hin Hmin) as Hn__2_is_pos.
      split.
      - assumption.
      - (* We can now look into penetrator strand p and see if n__2 belongs there *)
        specialize (Hunique_n__o (s, 1) N__b_originates_in_s1) as Hn__o_eq_s1; subst.
        intros Hptrace.
        assert (uns_term (s, 1) = ⟨ N__a # N__b ⟩_ PK A) as Hunsterms1.
        {
          simplify_term; rewrite <- Htrs; simpl; reflexivity.
        }
        assert (Hptrace' := Hptrace).
        unfold penetrator_strand in Hptrace'; apply P_is_penetrator in Hptrace'.
        (* As in the pen-and-paper proof, we go by cases on the penetrator trace *)
        inversion Hptrace' as [t|g|g|g h|g h|k Hpenkey|k h|k h].

        (* The easy_strand3 tactics, automatically solves the trivial cases. We are left with a few cases *)
        all: specialize (compute_minimal_NS H Hin Hmin) as Hcontra; easy_strand3.

        1: (* 1. Penetrator trace is [⊕ t] *)
          now specialize (Hunique_n__o (strand n__2, 0) (N__b_originates_in_n__20 _ Hsubterm0 H)).

        (*
          Next three cases share the same trace.
            - Lemmata NT4_4_not_empty_l/r, minimal_in_NT4_4_not_X_l/r for X ∈ { penetrator, initiator, responder } are used to make the proofs more modular
            - The first uses g, the second and third use h, hence we need four lemmata (maybe we can still simplify!)
            - From second to third suffices to use Hsubterm6 instead of Hsubterm7. Can we join them?
            - Unsure if a tactic could be helpful here
        *)
        1,2,3:
          (* 2.1 Penetrator trace is [⊖ g # h; ⊕ g; ⊕ h] and term n__2 = ⊕ g *)
          (* 2.2 Penetrator trace is [⊖ g # h; ⊕ g; ⊕ h] and term n__2 = ⊕ h *)
          (* 2.3 Penetrator trace is [⊖ g # h; ⊕ g; ⊕ h] and term n__2 = ⊕ h *)
          try specialize (NT4_4_not_empty_l Hin Hmin H Hcontra0 Hn2_in_C) as Hnonnil;
          try specialize (NT4_4_not_empty_r Hin Hmin H Hcontra0 Hn2_in_C) as Hnonnil;
          destruct (bundle_le_has_minimal C_is_bundle Hnonnil) as [n_min [Hn_min_in Hn_min]];
          destruct (Σ_is_ONS (strand n_min)) as [Hstrand|[Hstrand|Hstrand]];
          (*
            By the above lemmata (depending on the case), we know that n_min can lie on no strand.
            FIXME: auto with HintDb does not work because goal (False) does not matches HitDb pattern; Have a look if it is possible to fix this.
            Also, I'd refrain writing a tactic just for this case bc it would be very specific and would hinder the readability of this proof.
          *)
          revert Hstrand;
          now (
            apply (minimal_in_NT4_4_not_penetrator_l _ Hn_min_in Hn_min Hin Hmin Hcontra0 Hsubterm1 Hsubterm2) ||
            apply (minimal_in_NT4_4_not_initiator_l n__2 (n_min:=n_min) g h Hn_min_in Hn_min Hunsterms1 Hsubterm2 Hsubterm4) ||
            apply (minimal_in_NT4_4_not_responder_l n__2 (n_min:=n_min) g h Hn_min_in Hn_min Hunsterms1 Hsubterm2 Hsubterm4) ||
            apply (minimal_in_NT4_4_not_penetrator_r _ Hn_min_in Hn_min Hin Hmin Hcontra0 Hsubterm2 Hsubterm3) ||
            apply (minimal_in_NT4_4_not_initiator_r n__2 (n_min:=n_min) g h Hn_min_in Hn_min Hunsterms1 Hsubterm3 Hsubterm7) ||
            apply (minimal_in_NT4_4_not_responder_r n__2 (n_min:=n_min) g h Hn_min_in Hn_min Hunsterms1 Hsubterm3 Hsubterm7) ||
            apply (minimal_in_NT4_4_not_initiator_r n__2 (n_min:=n_min) g h Hn_min_in Hn_min Hunsterms1 Hsubterm3 Hsubterm6) ||
            apply (minimal_in_NT4_4_not_responder_r n__2 (n_min:=n_min) g h Hn_min_in Hn_min Hunsterms1 Hsubterm3 Hsubterm6)
          ).

        + (* 3. Penetrator trace is [⊖ inv k; ⊖ ⟨ h ⟩_ k; ⊕ h] *)
          destruct Hsubterm5 as [Heq|?]. all: try auto.
          rewrite Hunsterms1 in Heq.
          injection Heq as Hk Hh.
          destruct (never_originates_regular_dec (inv (PK A)) C) as [Hnever|Hnonnever].
          * specialize (min_index_by_term n__2) as Hn2_index; easy_strand_mibt_simple.
            assert ((strand n__2, 0) ⟹+ n__2) as Hintraplus by (apply lt_intrastrand_index; simpl; try lia; auto).
            specialize (intrastrand_trans_is_node_of  C_is_bundle Hn2_in_C Hintraplus) as H0_isbundle.
            specialize (penetrator_bound privA_npen Hnever H0_isbundle Hptrace) as Hpenbound.
            unfold uns_term, term in Hpenbound. simpl in Hpenbound.
            rewrite <- H in Hpenbound. simpl in Hpenbound.
            rewrite <- Hk in Hpenbound; contradiction.
          * unfold originates_regular in Hnonnever.
            destruct Hnonnever as [n [Hn_in_C [Horiginates_inv Hnopen]]].
            destruct Hnopen.
            unfold penetrator_node.
            specialize (Σ_is_ONS (strand n)).
            destruct Σ_is_ONS as [Hpen | [Hini|Hresp]].
            -- assumption.
            -- specialize (inv_PK_A_never_originates_initiator Horiginates_inv); contradiction.
            -- specialize (inv_PK_A_never_originates_responder Horiginates_inv); contradiction.
    Qed.

    Lemma regular_node_no_encr : forall n,
      ~ penetrator_node n ->
        (⟨ N__a # N__b ⟩_ PK A) ⊏ uns_term n ->
          (⟨ N__a # N__b ⟩_ PK A) = uns_term n.
    Proof.
      intros n Hreg Hsub.
      apply not_penetrator_is_regular in Hreg as [Hi | Hr].
      - unfold uns_term, term in *.
        destruct Hi as [A [B [N__a [N__b Hitr]]]]; inversion Hitr as [_ H].
        (* Go over all the indexes *)
        destruct (index n).
        + simpl in *. now destruct Hsub as [? | [? | [? | ?]]].
        + destruct n0.
          * simpl in *. destruct Hsub as [? | [? | [? | ?]]].
            all: (auto || discriminate).
          * destruct n0.
            -- simpl in *. now destruct Hsub as [? | ?].
            -- simpl in *. destruct n0. all: (simpl in *; now apply tau_incompat in Hsub).
      - unfold uns_term, term in *.
        destruct Hr as [A [B [N__a [N__b Hrtr]]]]; inversion Hrtr as [_ H].
        (* Go over all the indexes *)
        destruct (index n).
        + simpl in *. now destruct Hsub as [? | [? | [? | ?]]].
        + destruct n0.
          * simpl in *. destruct Hsub as [? | [? | [? | ?]]].
            all: (auto || discriminate).
          * destruct n0.
            -- simpl in *. now destruct Hsub as [? | ?].
            -- simpl in *. destruct n0. all: (simpl in *; now apply tau_incompat in Hsub).
    Qed.

    Lemma no_prec_of_minimal_in_NS : forall n n__2, C ⊢ n ⪯ n__2 -> n <> n__2 -> set_In n__2 NS -> is_minimal (bundle_le C) n__2 NS -> ~ set_In n NS.
    Proof.
      intros n n__2 Hprec Hneq Hin_n__2 Hmin Hin_n.
      now specialize (Hmin Hin_n__2 n Hin_n Hneq).
    Qed.

    (* Lemma 4.6 changes a bit!
      If we pick n__2 as in Lemma 4.4, we can conclude that a node
      n__1 = ⟨ Na#Nb ⟩_(PK A) precedes n__2 on the same strand.
    *)
    Lemma n__1_precedes_n__2_on_same_strand :
      forall n__2,
        set_In n__2 NS -> is_minimal (bundle_le C) n__2 NS ->
          exists n__1, n__1 ⟹+ n__2 /\ ⟨ N__a # N__b ⟩_(PK A) = uns_term n__1.
    Proof.
      inversion trace_of_s as [_ Htrs].

      intros n__2 Hin Hmin.
      (* We know that n__2 is regular and positive *)
      specialize (minimal_regular_and_positive Hin Hmin) as [Hn__2_is_pos Hn__2_is_reg].
      (* By Lemma 4.3, N__b originates at n__0 = (s, 1), uniquely in Σ by N__b_uniquely_originates *)
      specialize N__b_originates_in_s1 as N__b_originates.

      assert (Hin':=Hin).
      apply filter_In in Hin' as [Hn2_in_C Hn2_prop].

      (* We can now derive two key properties of n__2, to be used later: HN__b_sub_n__2 and Hs_1_nsub_n__2*)
      unfold f_NS in Hn2_prop.
      apply andb_true_iff in Hn2_prop as [HN__b_sub_n__2 Hs_1_nsub_n__2].
      apply negb_true_iff in Hs_1_nsub_n__2.
      apply subterm_iff_subtermb_not in Hs_1_nsub_n__2.
      apply subterm_iff_subtermb in HN__b_sub_n__2.
      unfold uns_term at 1 in Hs_1_nsub_n__2. unfold term at 1 in Hs_1_nsub_n__2. simpl in Hs_1_nsub_n__2.
      rewrite <- Htrs in Hs_1_nsub_n__2.
      simpl in Hs_1_nsub_n__2.

      (* From the above two properties we derive that:
          1. n__2 differs from (s, 1)
          2. (thus) N__b does not originate in n__2
      *)
      assert ((⟨ N__a # N__b ⟩_(PK A)) ⊏ uns_term (s, 1)) as Hsub by (simplify_term; rewrite <- Htrs; simpl; now left).

      assert (n__2 <> (s, 1)) as Hneq.
      {
        intros Heq.
        apply (f_equal uns_term) in Heq.
        now rewrite <- Heq in Hsub.
      }

      assert (not (originates N__b n__2)) as HN__b_not_orig_n__2.
      {
        intros HN__b_orig_n__2.
        destruct N__b_uniquely_originates as [n__o [Horig_n__o Hunique_n__o]].
        specialize (Hunique_n__o _ N__b_originates) as Horig_s1.
        specialize (Hunique_n__o _ HN__b_orig_n__2) as Horig_n__2.
        now rewrite Horig_n__2 in Horig_s1.
      }

      (* We can use decidability of originates to derive that there is some n__1 preceding n__2 of which N__b is subterm *)
      assert (exists n', n' ⟹+ n__2 /\ N__b ⊏ uns_term n') as [n__1 [Hn__1_intra_n__2 HN__b_sub_n__1]].
      {
        apply not_originates_non_originates in HN__b_not_orig_n__2.
        unfold non_originates in HN__b_not_orig_n__2.
        destruct HN__b_not_orig_n__2 as [Hnorig | [Hnsub | Hex]].
        all: easy.
      }

      exists n__1.
      split.
      - (* This is *) easy.
      - (* This is a consequence of minimality:
          - n__1 cannot belong to NS because of minimality of n__2
          - thus, n__1 must be such that N__b ⊏ term n__1
          - finally, since n__1 is regular, we prove the goal by regular_node_no_encr
        *)
        specialize (intrastrand_trans_is_node_of C_is_bundle Hn2_in_C Hn__1_intra_n__2) as Hn__1_is_node.
        specialize (intrastrand_implies_ecrt C_is_bundle Hn2_in_C Hn__1_intra_n__2) as Hn__1_prec_n__2.
        specialize (no_prec_of_minimal_in_NS Hn__1_prec_n__2 (intrastrand_irreflexive Hn__1_intra_n__2) Hin Hmin) as Hnin.
        unfold is_node_of in Hn__1_is_node.
        unfold set_In in Hnin. unfold NS in Hnin. rewrite filter_In in Hnin.
        unfold f_NS in Hnin.
        rewrite andb_true_iff in Hnin.
        rewrite <- subterm_iff_subtermb in Hnin.
        rewrite negb_true_iff in Hnin.
        rewrite <- subterm_iff_subtermb_not in Hnin.
        unfold not in Hnin.

        (* Since n__1 is regular, we apply regular_node_no_encr and finish! *)
        assert (~ penetrator_node n__1) as Hnpen_n__1.
        {
          apply intrastrand_same in Hn__1_intra_n__2.
          unfold penetrator_node.
          now rewrite Hn__1_intra_n__2.
        }

        crush. (* FIXME: Remove the crush! *)
        destruct (A_subterm_dec (uns_term (s, 1)) (uns_term n__1)) as [Hs | Hns].
        + unfold uns_term in Hs at 1; unfold term in Hs at 1; simpl in Hs; rewrite <- Htrs in Hs; simpl in Hs.
          apply (regular_node_no_encr Hnpen_n__1 Hs).
        + contradiction.
    Qed.

    (* Lemma 4.7 part 1: The strand of n__1 and n__2 is an initiator strand *)
    Lemma strand_n__2_is_initiator :
      forall n__2,
      set_In n__2 NS -> is_minimal (bundle_le C) n__2 NS ->
        ONS_initiator_strand (strand n__2).
    Proof.
      intros n__2 Hn__2_in Hn__2_min.
      (* We know that n__2 is regular and positive *)
      specialize (minimal_regular_and_positive Hn__2_in Hn__2_min) as [Hn__2_is_pos Hn__2_is_reg].

      (* Recall the definition of n__1 from Lemma 4.6 *)
      specialize (n__1_precedes_n__2_on_same_strand Hn__2_in Hn__2_min) as [n__1 [Hn__1_intra_n__2 Hn1_eq]].
      (* We go by cases on the possible shapes that the strand of n__2 can assume *)
      specialize (Σ_is_ONS (strand n__2)) as [Hpen | [Hinit | Hresp]].
      all: try easy.
      (* After easily proving trivial cases, we are left to prove that the strand is *not* a responder strand *)
      apply intrastrand_same in Hn__1_intra_n__2 as Hsame.
      rewrite <- Hsame in *.
      inversion Hresp as [A [B [N__a [N__b H]]]]; inversion H as [Hname Htr].
      assert (Hn1_eq':=Hn1_eq).
      unfold uns_term, term in Hn1_eq.
      rewrite <- Htr in Hn1_eq.
      specialize (min_index_by_term_uns n__1) as Hmin.
      easy_strand_mibt_simple.

      - (* Here we use the positivity of n__2 to derive a contradiction *)
          apply intrastrand_index_lt in Hn__1_intra_n__2.
          (* rewrite Hi1 in Hn__1_intra_n__2. *)
          destruct (index n__2) as [| i2] eqn:Hi2.
          -- easy.
          -- destruct i2 as [|i2'].
            ++ apply lt_1_r in Hn__1_intra_n__2.
              unfold uns_term, term in Hn1_eq'. rewrite Hn__1_intra_n__2 in Hn1_eq'. rewrite <- Htr in Hn1_eq'.
              simpl in Hn1_eq'. inversion Hn1_eq'. inversion Hsubterm.
              now subst. (* N__b is not a name, but A is! *)
            ++ destruct i2' as [|i2''].
              ** unfold is_positive in Hn__2_is_pos. unfold term in Hn__2_is_pos. rewrite Hsame in Htr. rewrite <- Htr in Hn__2_is_pos. rewrite Hi2 in Hn__2_is_pos. now simpl in Hn__2_is_pos.
              ** destruct i2'' as [|i2'''].
                all: (unfold is_positive in Hn__2_is_pos; unfold term in Hn__2_is_pos; rewrite Hsame in Htr; rewrite <- Htr in Hn__2_is_pos; rewrite Hi2 in Hn__2_is_pos; now simpl in Hn__2_is_pos).
      - (* Copy-pasted from previous part, maybe it is worth looking in removing the duplication! *)
        apply intrastrand_index_lt in Hn__1_intra_n__2.
        (* rewrite Hi1 in Hn__1_intra_n__2. *)
        destruct (index n__2) as [| i2] eqn:Hi2.
        -- easy.
        -- destruct i2 as [|i2'].
          ++ apply lt_1_r in Hn__1_intra_n__2.
            unfold uns_term, term in Hn1_eq'. rewrite Hn__1_intra_n__2 in Hn1_eq'. rewrite <- Htr in Hn1_eq'.
            simpl in Hn1_eq'. inversion Hn1_eq'. inversion Hsubterm0.
            now subst. (* N__b is not a name, but A is! *)
          ++ destruct i2' as [|i2''].
            ** unfold is_positive in Hn__2_is_pos. unfold term in Hn__2_is_pos. rewrite Hsame in Htr. rewrite <- Htr in Hn__2_is_pos. rewrite Hi2 in Hn__2_is_pos. now simpl in Hn__2_is_pos.
            ** destruct i2'' as [|i2'''].
              all: (unfold is_positive in Hn__2_is_pos; unfold term in Hn__2_is_pos; rewrite Hsame in Htr; rewrite <- Htr in Hn__2_is_pos; rewrite Hi2 in Hn__2_is_pos; now simpl in Hn__2_is_pos).
      - specialize (term_uns_overflow n__1) as Hover.
        rewrite <- Htr in Hover. simpl in Hover.
        apply Hover in Hmin.
        now rewrite <- Hn1_eq' in Hmin.
    Qed.

    (* Lemma 4.7 part 2: The strand of n__1 and n__2 belongs to C *)
    Lemma strand_n__2_is_in_C :
      forall n__2,
      set_In n__2 NS -> is_minimal (bundle_le C) n__2 NS ->
        is_strand_of (strand n__2) C.
    Proof.
      intros n__2 Hn__2_in Hn__2_min.

      (* We know that n__2 is regular and positive *)
      specialize (minimal_regular_and_positive Hn__2_in Hn__2_min) as [Hn__2_is_pos Hn__2_is_reg].

      (* Since strand n__2 is an initiator strand, we know it has a specific form... *)
      specialize (strand_n__2_is_initiator Hn__2_in Hn__2_min) as Hinit.
      inversion Hinit as [A [B [N__a [N__b H]]]]; inversion H as [Hname Htr].

      (* Recall the definition of n__1 from Lemma 4.6 *)
      specialize (n__1_precedes_n__2_on_same_strand Hn__2_in Hn__2_min) as [n__1 [Hn__1_intra_n__2 Hn1_eq]].
      apply intrastrand_index_lt in Hn__1_intra_n__2 as Hn__1_lt_n__2.
      apply intrastrand_same in Hn__1_intra_n__2 as Hn__1_same_n__2.

      assert (index n__1 = 1) as Hidxn__1.
      {
        unfold uns_term, term in Hn1_eq.
        rewrite <- Hn__1_same_n__2 in Htr.
        rewrite <- Htr in Hn1_eq.
        destruct (index n__1) as [|i].
        - simpl in Hn1_eq. inversion Hn1_eq. now subst.
        - destruct i as [|i]. all: simpl in *.
          + easy.
          + destruct i as [|i]. all: simpl in *.
            * easy.
            * destruct i as [|i].
              all: simpl in *; apply eq_then_sub in Hn1_eq; now (apply tau_incompat in Hn1_eq).
      }

      assert (index n__2 = 2) as Hidxn__2.
      {
        unfold is_positive, term in Hn__2_is_pos. rewrite <- Htr in Hn__2_is_pos.
        destruct (index n__2) as [|i2].
        - easy.
        - destruct i2 as [|i2].
          + lia.
          + destruct i2 as [|i2].
            * easy.
            * destruct i2 as [|i2].
              all: now simpl in *.
      }

      unfold is_strand_of.
      intros n Heqstrand Hindex.
      unfold is_node_of.

      specialize (node_as_pair n) as Hn_pair.
      specialize (node_as_pair n__1) as Hn__1_pair.
      specialize (node_as_pair n__2) as Hn__2_pair.
      rewrite Heqstrand in Hn_pair.

      apply filter_In in Hn__2_in as [Hn2_in_C _].

      destruct (index n) as [| i] eqn:Hidxn.
      - (* index n may be 0 *)
        specialize (lt_lt_0 (index n__1) (index n__2) Hn__1_lt_n__2) as Hlt.
        specialize (lt_intrastrand_index_0 (strand n__2) Hlt) as Hintra.
        rewrite Hn__2_pair in Hn2_in_C.
        subst.
        apply (intrastrand_implies_is_node_of C_is_bundle Hn2_in_C Hintra).
      - (* Or, it may be >= 1 *)
        destruct i as [| i].
        + (* index n = 1 *) rewrite <- Hidxn in Hidxn__1. rewrite Hidxn__1 in Hn__1_lt_n__2.
          rewrite Hidxn__1 in Hn__1_pair.
          rewrite Hn__1_same_n__2 in Hn__1_pair.
          rewrite Hn__1_pair in Hn__1_intra_n__2.
          rewrite Hn_pair.
          rewrite <- Hidxn.
          apply (intrastrand_implies_is_node_of C_is_bundle Hn2_in_C Hn__1_intra_n__2).
        + (* Or maybe it is >= 2 *)
          destruct i as [| i].
          * (* index n = 2 *) rewrite <- Hidxn__2 in Hn_pair; rewrite <- Hn__2_pair in Hn_pair; now subst.
          * (* index n >= 3 *)
            rewrite <- Heqstrand in Htr.
            rewrite <- Htr in Hindex. simpl in Hindex. lia.
    Qed.


    (*
      Now we would like to have non-injective agreement (analogous to Proposition 4.2).
      We fail:
      unfortunately, we cannot establish the identity of who's executing the "B" role, i.e., we cannot say that the trace of t is an initiator strand with second "B"'s identity known.
    *)
    Proposition noninjective_agreement : exists t : Σ,
      ONS_initiator_strand t /\
        (exists D, ONS_initiator_traces A D N__a N__b (tr t)) /\
          is_strand_of t C.
    Proof.
      (* Since NS is not empty, it exists a minimal element belonging there --- Lemma 4.4 part 2 *)
      specialize (NS_has_minimal) as [n__2 [Hn__2_in Hn__2_min]].
      specialize (strand_n__2_is_initiator Hn__2_in Hn__2_min) as Hn__2_init.
      inversion Hn__2_init.
      exists (strand n__2).
      split. 2: split.
      - (* Lemma 4.7 part 1: n__2 is on an initiator strand *) apply Hn__2_init.
      - (* unfold NS in Hin. *)
        (* apply filter_In in Hin as [Hn__2_in Heq]. *)
        (* Recall the definition of n__1 from Lemma 4.6 *)
        specialize (n__1_precedes_n__2_on_same_strand Hn__2_in Hn__2_min) as [n__1 [Hn__1_intra_n__2 Hn1_eq]].
        (* apply intrastrand_index_lt in Hn__1_intra_n__2 as Hn__1_lt_n__2. *)
        apply intrastrand_same in Hn__1_intra_n__2 as Hn__1_same_n__2.
        inversion Hn__2_init as [A' [B' [N'__a [N'__b Hn__2_i]]]]; inversion Hn__2_i as [Hnames Hn__2_tr].
        assert (index n__1 = 1) as Hidxn__1.
        {
          unfold uns_term, term in Hn1_eq.
          rewrite <- Hn__1_same_n__2 in Hn__2_tr.
          rewrite <- Hn__2_tr in Hn1_eq.
          destruct (index n__1) as [|i].
          - simpl in Hn1_eq. inversion Hn1_eq. subst. easy.
          - destruct i as [|i]. all: simpl in *.
            + easy.
            + destruct i as [|i]. all: simpl in *.
              * easy.
              * destruct i as [|i].
                all: simpl in *; apply eq_then_sub in Hn1_eq; now (apply tau_incompat in Hn1_eq).
        }
        rewrite <- Hn__1_same_n__2 in Hn__2_tr.
        unfold uns_term, term in Hn1_eq. rewrite <- Hn__2_tr in Hn1_eq. rewrite Hidxn__1 in Hn1_eq. simpl in Hn1_eq.
        inversion Hn1_eq. apply PK_injective in H1. exists B'. now subst.
      - (* Lemma 4.7 part 2: strand n__2 belongs to C *) apply (strand_n__2_is_in_C Hn__2_in Hn__2_min).
    Qed.

    (* Now it's time for Proposition 4.8, again a bit different that the one for NSL *)
    Proposition injective_agreement :
        uniquely_originates N__a ->
          exists! t, (exists D, ONS_initiator_traces A D N__a N__b (tr t)).
    Proof.
      intros N__a_uniquely_originates.
      specialize (noninjective_agreement) as [t [_ [[D Ht_init_tr] Ht_in_C]]].
      inversion Ht_init_tr as [_ Htr].
      exists t.
      unfold unique.
      split.
      - exists D. assumption.
      - intros t' [D' Ht'_init].
        inversion Ht'_init as [_ Htr'].
        assert (originates N__a (t, 0)) as HN__a_orig.
        {
          unfold originates. split. 2: split.
          - unfold is_positive, term; simpl. rewrite <- Htr; now simpl.
          - unfold uns_term, term; simpl; rewrite <- Htr. simpl. now right; right; left.
          - intros n' Hintra. apply intrastrand_index_lt in Hintra. simpl in Hintra. lia.
        }

        assert (originates N__a (t', 0)) as HN__a_orig'.
        {
          unfold originates. split. 2: split.
          - unfold is_positive, term; simpl; rewrite <- Htr'; now simpl.
          - unfold uns_term, term; simpl; rewrite <- Htr'. simpl. now right; right; left.
          - intros n' Hintra. apply intrastrand_index_lt in Hintra. simpl in Hintra. lia.
        }

        unfold uniquely_originates in N__a_uniquely_originates.
        (* This is the key step! *)
        destruct N__a_uniquely_originates as [n [_ Hunique]].
        specialize (Hunique (t, 0) HN__a_orig) as Hun_n; apply (f_equal strand) in Hun_n; simpl in Hun_n.
        specialize (Hunique (t', 0) HN__a_orig') as Hun_n'; apply (f_equal strand) in Hun_n'; simpl in Hun_n'.
        now subst.
    Qed.
  End auth_responder_guarantee.

  (* This section proves that the protocol keeps N__b secret *)
  Section secrecy_responder_nonce.


  End secrecy_responder_nonce.
End ONS.

